# Database (pgvector-enabled Postgres)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cv_rag_poc

# LiteLLM proxy (master key atau virtual key)
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=

# Model LLM & embedding (dikonfigurasi di LiteLLM, bisa diganti tanpa ubah kode)
LLM_MODEL=deepinfra/deepseek-ai/DeepSeek-V4-Flash
EMBEDDING_MODEL=openai/BAAI/bge-m3

# Chunking defaults (bisa dioverride per-request lewat API)
DEFAULT_CHUNK_SIZE_TOKENS=500
DEFAULT_CHUNK_OVERLAP_TOKENS=50

# Response language default
DEFAULT_RESPONSE_LANGUAGE=en

# Upload constraints
MAX_UPLOAD_SIZE_MB=10

LOG_LEVEL=INFO
